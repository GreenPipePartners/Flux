[Unit]
Description=Flux Web
After=network-online.target
Wants=network-online.target

[Service]
User=flux
Group=flux
WorkingDirectory=/opt/flux
EnvironmentFile=/etc/flux/flux.env
ExecStart=/opt/flux/.venv/bin/gunicorn flux.wsgi:application --bind 0.0.0.0:8000
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
