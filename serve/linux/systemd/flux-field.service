[Unit]
Description=Flux Field OPC UA Agent
After=network-online.target flux-web.service
Wants=network-online.target

[Service]
User=flux
Group=flux
WorkingDirectory=/opt/flux/field/Flux.FieldAgent
EnvironmentFile=/etc/flux/flux.env
ExecStart=/opt/flux/field/Flux.FieldAgent/Flux.FieldAgent
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
