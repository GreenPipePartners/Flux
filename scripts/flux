#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import socket
import urllib.error
import urllib.request
import webbrowser
from pathlib import Path

ROOT_DIR = Path(__file__).resolve().parents[1]
WEB_URL = "http://localhost:8000/"
DOCS_URL = "http://localhost:8001/"
WEB_DIR = ROOT_DIR / "web" / "Flux"
WEB_ENV = WEB_DIR / ".env"
FLUXY_PROJECT = ROOT_DIR / "web" / "ignition_flux_project"
DEFAULT_GATEWAY_URL = "http://localhost:8088"
DEFAULT_FLUXY_BASE_URL = "http://localhost:8088/system/webdev/flux"


INTRO = f"""
Flux
====

Flux is a local Ignition companion stack for fast, database-backed operations views.

Local stack:
  Web UI       {WEB_URL}
  Docs         {DOCS_URL}
  FieldAgent   OPC UA simulator on opc.tcp://localhost:4840/flux/field
  QuestDB      Trace data plane on postgresql://admin:quest@localhost:8812/qdb
  Demo reader  Reads Ignition through Fluxy and stores latest values in Flux

Common commands:
  flux doctor           Check local Flux + Ignition dev-cell health
  flux start            Start the Flux background service
  flux start --web-mode dev
                        Start with Django runserver for UI iteration
  flux stop             Stop the Flux background service
  flux restart          Restart the Flux background service
  flux restart --web-mode gunicorn
                        Restart with prod-like Gunicorn workers
  flux status           Show service status
  flux logs             Follow service logs
  flux open             Open the web UI
  flux docs serve       Start the local docs server
  flux docs open        Open the local docs site
  flux install-service  Install/refresh the user service

Ignition dev cell:
  flux ignition doctor        Check Gateway + Fluxy WebDev readiness
  flux ignition deploy-fluxy  Deploy/refresh Fluxy WebDev resources
  flux ignition request-scan  Ask Ignition to rescan the project
  flux ignition open          Open the Ignition Gateway home page

Field simulation:
  flux field import-tag-data   Import tag_data inventory + provider export
  flux field import-live       Import live Ignition provider + device list
  flux field materialize       Materialize imported sim catalog into FieldAgent config
  flux field configure-ignition Configure Ignition OPC UA connections and OPC tags
  flux field supervisor        Run supervised per-device FieldAgent processes

Migration mining/build:
  flux mine source PATH        Persist mine facts from PLC or FactoryTalk source/ZIP
  flux mine parse-l5x FILE       Parse an L5X file and print recovered PLC summary
  flux mine parse-l5k FILE       Parse an L5K file and print recovered PLC summary
  flux build ignition-tags FILE  Generate Ignition tag provider JSON from an L5X/L5K file
  flux build ignition-tags-run ID Generate Ignition tag provider JSON from a mine run
  flux build hmi-map SOURCE      Generate symbolic HMI map artifacts from an HMI source
  flux build hmi-map-run ID      Generate symbolic HMI map artifacts from a mine run
  flux build seed-hmi-demo       Seed the verified HMI SQLite demo sample
  flux cell seed-demo            Seed a sample cell backed by cached runtime/trace data
  flux cell import DIR           Import a Flux.cell CSV bundle
  flux cell export KEY           Export Flux.cell Live/Trace CSV views
  flux deep init-hello-world      Seed the Flux.Deep Logix/OpenPLC hello_world workspace

First local setup:
  1. Run: flux install-service
  2. Run: flux start
  3. Open: {WEB_URL}

Project paths:
  Repo      {ROOT_DIR}
  Web app   {ROOT_DIR / "web" / "Flux"}
  Dev cell  {ROOT_DIR / "docs" / "ignition-dev-cell.md"}
""".strip()


def script(name: str) -> Path:
    return ROOT_DIR / "scripts" / f"{name}.sh"


def require_linux() -> int:
    if sys.platform == "linux":
        return 0
    print("Flux is Linux-exclusive. Run Flux on Linux with systemd and bash.", file=sys.stderr)
    return 2


def flux_env() -> dict[str, str]:
    env = os.environ.copy()
    if WEB_ENV.exists():
        for line in WEB_ENV.read_text(encoding="utf-8").splitlines():
            stripped = line.strip()
            if not stripped or stripped.startswith("#") or "=" not in stripped:
                continue
            key, value = stripped.split("=", 1)
            env.setdefault(key.strip(), value.strip().strip('"').strip("'"))
    env.setdefault("IGNITION_GATEWAY_URL", DEFAULT_GATEWAY_URL)
    env.setdefault("FLUXY_BASE_URL", DEFAULT_FLUXY_BASE_URL)
    env.setdefault("FLUXY_PROJECT_LOCATION", str(FLUXY_PROJECT))
    return env


def run_uv_fluxy(args: list[str]) -> int:
    return subprocess.call(["uv", "run", "--project", "fluxy", *args], cwd=ROOT_DIR, env=flux_env())


def run_uv_mine(args: list[str]) -> int:
    return subprocess.call(["uv", "run", "--project", "mine", *args], cwd=ROOT_DIR, env=flux_env())


def run_uv_build(args: list[str]) -> int:
    return subprocess.call(["uv", "run", "--project", "build", *args], cwd=ROOT_DIR, env=flux_env())


def run_uv_deep(args: list[str]) -> int:
    return subprocess.call(["uv", "run", "--project", "deep", *args], cwd=ROOT_DIR, env=flux_env())


def run_manage(args: list[str]) -> int:
    return subprocess.call(["uv", "run", "python", "manage.py", *args], cwd=WEB_DIR, env=flux_env())


def run_docs(args: list[str]) -> int:
    return subprocess.call(
        ["uv", "run", "--project", str(WEB_DIR), "mkdocs", *args], cwd=ROOT_DIR, env=flux_env()
    )


def capture(command: list[str], *, cwd: Path = ROOT_DIR) -> subprocess.CompletedProcess[str]:
    return subprocess.run(command, cwd=cwd, text=True, capture_output=True, env=flux_env())


def check_http(url: str, timeout: float = 3.0) -> tuple[bool, str]:
    try:
        with urllib.request.urlopen(url, timeout=timeout) as response:
            return 200 <= response.status < 400, f"HTTP {response.status}"
    except urllib.error.HTTPError as exc:
        return False, f"HTTP {exc.code}"
    except OSError as exc:
        return False, str(exc)


def check_port(host: str, port: int, timeout: float = 2.0) -> tuple[bool, str]:
    try:
        with socket.create_connection((host, port), timeout=timeout):
            return True, "listening"
    except OSError as exc:
        return False, str(exc)


def print_check(ok: bool, name: str, detail: str) -> None:
    marker = "OK" if ok else "FAIL"
    print(f"[{marker}] {name}: {detail}")


def print_fix(command: str) -> None:
    print(f"      fix: {command}")


def django_doctor_state() -> tuple[dict | None, str]:
    result = capture(["uv", "run", "python", "manage.py", "flux_doctor_state"], cwd=WEB_DIR)
    if result.returncode != 0:
        return None, (result.stderr or result.stdout).strip()
    try:
        return json.loads(result.stdout), ""
    except json.JSONDecodeError as exc:
        return None, f"Invalid doctor state JSON: {exc}"


def doctor() -> int:
    failures = 0

    service = capture(["systemctl", "--user", "is-active", "flux-stack.service"])
    service_ok = service.returncode == 0 and service.stdout.strip() == "active"
    print_check(
        service_ok, "Flux service", service.stdout.strip() or service.stderr.strip() or "not active"
    )
    if not service_ok:
        print_fix("flux start")
    failures += 0 if service_ok else 1

    web_ok, web_detail = check_http(WEB_URL)
    print_check(web_ok, "Flux web", f"{WEB_URL} {web_detail}")
    if not web_ok:
        print_fix("flux start")
    failures += 0 if web_ok else 1

    docs_ok, docs_detail = check_http(DOCS_URL)
    print_check(docs_ok, "Flux docs", f"{DOCS_URL} {docs_detail}")
    if not docs_ok:
        print_fix("flux docs serve")
        print_fix("flux restart")
    failures += 0 if docs_ok else 1

    field_ok, field_detail = check_port("localhost", 4840)
    print_check(field_ok, "FieldAgent OPC UA", f"localhost:4840 {field_detail}")
    if not field_ok:
        print_fix("flux start")
    failures += 0 if field_ok else 1

    state, state_error = django_doctor_state()
    if state is None:
        print_check(False, "Flux app state", state_error or "unavailable")
        print_fix("cd web/Flux && uv run python manage.py migrate")
        failures += 1
    else:
        runtime = state["runtime"]
        bridge = state["bridge"]
        historian = state["historian"]

        latest_age = runtime["latest_read_age_seconds"]
        latest_detail = "no reads yet" if latest_age is None else f"latest read {latest_age}s ago"
        hidden_count = runtime.get("excluded_interface_tag_count", 0)
        hidden_detail = f", {hidden_count} hidden trial/stress" if hidden_count else ""
        runtime_ok = (
            runtime["tag_count"] > 0
            and runtime["stale_count"] == 0
            and runtime["bad_quality_count"] == 0
        )
        print_check(
            runtime_ok,
            "Runtime reads",
            "%s tags%s, %s online, %s stale, %s bad quality, %s"
            % (
                runtime["tag_count"],
                hidden_detail,
                runtime["online_count"],
                runtime["stale_count"],
                runtime["bad_quality_count"],
                latest_detail,
            ),
        )
        if runtime["stale_count"]:
            print_fix("open http://localhost:8000/ and use 'Refresh stale reads now'")
        if runtime["tag_count"] == 0:
            print_fix("open http://localhost:8000/admin/runtime/runtimetag/")
        failures += 0 if runtime_ok else 1

        bridge_ok = bridge["online"] and bridge["token_set"]
        bridge_detail = "%s, token %s" % (
            bridge["base_url"],
            "set" if bridge["token_set"] else "not set",
        )
        if bridge["message"]:
            bridge_detail = f"{bridge_detail}, {bridge['message']}"
        print_check(bridge_ok, "Live Ignition Bridge", bridge_detail)
        if not bridge_ok:
            print_fix("open http://localhost:8000/ and use Live Ignition Bridge -> Test connection")
        failures += 0 if bridge_ok else 1

        historian_ok = historian["ok"] and historian["status"].lower() == "valid"
        historian_detail = "%s type=%s status=%s" % (
            historian["database"],
            historian["db_type"] or "unknown",
            historian["status"] or historian["error"] or "unknown",
        )
        print_check(historian_ok, "Historian datasource", historian_detail)
        if not historian_ok:
            print_fix("verify FLUX_HISTORIAN_DATABASE or Ignition datasource status")
        failures += 0 if historian_ok else 1

        questdb = state.get("questdb", {})
        questdb_ok = bool(questdb.get("ok"))
        questdb_detail = "%s, %s Plane samples" % (
            questdb.get("dsn", "postgresql://admin:quest@localhost:8812/qdb"),
            questdb.get("plane_samples", 0),
        )
        if questdb.get("latest_timestamp"):
            questdb_detail = f"{questdb_detail}, latest {questdb['latest_timestamp']}"
        if questdb.get("error"):
            questdb_detail = f"{questdb_detail}, {questdb['error']}"
        print_check(questdb_ok, "QuestDB Trace data plane", questdb_detail)
        if not questdb_ok:
            print_fix("scripts/questdb-start.sh")
            print_fix(
                "cd web/Flux && uv run python manage.py sync_trace_questdb --limit 10 --replace"
            )
        failures += 0 if questdb_ok else 1

    ignition = capture(["uv", "run", "--project", "fluxy", "fluxy-check-ignition-dev"])
    ignition_ok = ignition.returncode == 0
    print_check(ignition_ok, "Ignition dev cell", "ready" if ignition_ok else "not ready")
    if not ignition_ok:
        print_fix("flux ignition doctor --open")
    output = (ignition.stdout or ignition.stderr).strip()
    if output:
        for line in output.splitlines():
            print(f"      {line}")
    failures += 0 if ignition_ok else 1

    if failures:
        print("Flux is not fully healthy.")
        return 1
    print("Flux is healthy.")
    return 0


def run_script(name: str, env_updates: dict[str, str] | None = None) -> int:
    path = script(name)
    if not path.exists():
        print(f"Flux command is not available on this platform yet: {path}", file=sys.stderr)
        return 1
    env = os.environ.copy()
    if env_updates:
        env.update(env_updates)
    return subprocess.call([str(path)], cwd=ROOT_DIR, env=env)


def service_env(args: argparse.Namespace) -> dict[str, str]:
    updates = {}
    web_mode = getattr(args, "web_mode", None)
    if web_mode:
        updates["FLUX_WEB_MODE"] = web_mode
    return updates


def open_ui() -> int:
    opened = webbrowser.open(WEB_URL)
    if not opened:
        print(WEB_URL)
        return 1
    print(f"Opened {WEB_URL}")
    return 0


def docs_serve(args: argparse.Namespace) -> int:
    return run_docs(["serve", "--dev-addr", f"{args.host}:{args.port}"])


def docs_build(_args: argparse.Namespace) -> int:
    return run_docs(["build", "--strict"])


def open_url(url: str) -> int:
    opened = webbrowser.open(url)
    if not opened:
        print(url)
        return 1
    print(f"Opened {url}")
    return 0


def ignition_doctor(args: argparse.Namespace) -> int:
    command = [
        "fluxy-check-ignition-dev",
        "--gateway-url",
        args.gateway_url,
        "--fluxy-base-url",
        args.fluxy_base_url,
        "--timeout",
        str(args.timeout),
    ]
    token = args.token if args.token is not None else flux_env().get("FLUXY_TOKEN")
    if token:
        command.extend(["--token", token])
    if args.open:
        command.append("--open")
    return run_uv_fluxy(command)


def ignition_deploy_fluxy(args: argparse.Namespace) -> int:
    project_path = Path(args.project_path).expanduser().resolve()
    if not project_path.exists():
        print(f"Ignition project path does not exist: {project_path}", file=sys.stderr)
        return 1

    command = ["fluxy-deploy-webdev", str(project_path), "--namespace", args.namespace]
    if args.clean:
        command.append("--clean")
    token = args.auth_token if args.auth_token is not None else flux_env().get("FLUXY_TOKEN")
    if token:
        command.extend(["--auth-token", token])

    status = run_uv_fluxy(command)
    if status != 0 or args.no_scan:
        return status
    return ignition_request_scan(args)


def ignition_request_scan(args: argparse.Namespace) -> int:
    env = flux_env()
    base_url = getattr(args, "fluxy_base_url", None) or env["FLUXY_BASE_URL"]
    token = getattr(args, "token", None)
    if token is None:
        token = env.get("FLUXY_TOKEN")
    code = (
        "import os, fluxy; "
        "fx = fluxy.Fluxy(base_url=os.environ['FLUXY_BASE_URL'], token=os.environ.get('FLUXY_TOKEN')); "
        "print(fx.project.request_scan())"
    )
    env["FLUXY_BASE_URL"] = base_url
    if token:
        env["FLUXY_TOKEN"] = token
    return subprocess.call(
        ["uv", "run", "--project", "fluxy", "python", "-c", code], cwd=ROOT_DIR, env=env
    )


def ignition_info() -> int:
    env = flux_env()
    print("Flux Ignition dev cell")
    print("=======================")
    print(f"Gateway URL:       {env['IGNITION_GATEWAY_URL']}")
    print(f"Fluxy base URL:    {env['FLUXY_BASE_URL']}")
    print(f"Project location:  {env['FLUXY_PROJECT_LOCATION']}")
    print(f"Fluxy token:       {'set' if env.get('FLUXY_TOKEN') else 'not set'}")
    return 0


def field_import_tag_data(args: argparse.Namespace) -> int:
    command = [
        "import_tag_data_catalog",
        args.provider,
        "--devices",
        args.devices,
        "--tags",
        args.tags,
    ]
    if args.skip_raw_config:
        command.append("--skip-raw-config")
    return run_manage(command)


def field_import_live(args: argparse.Namespace) -> int:
    command = [
        "import_live_tag_catalog",
        args.source_provider,
        "--base-url",
        args.base_url,
    ]
    token = args.token if args.token is not None else flux_env().get("FLUXY_TOKEN")
    if token:
        command.extend(["--token", token])
    if args.provider:
        command.extend(["--provider", args.provider])
    if args.skip_raw_config:
        command.append("--skip-raw-config")
    return run_manage(command)


def field_materialize(args: argparse.Namespace) -> int:
    command = ["materialize_sim_field_config"]
    if args.provider:
        command.extend(["--provider", args.provider])
    return run_manage(command)


def field_configure_ignition(args: argparse.Namespace) -> int:
    command = [
        "configure_field_ignition",
        "--base-url",
        args.base_url,
        "--tag-provider",
        args.tag_provider,
        "--tag-folder",
        args.tag_folder,
        "--collision-policy",
        args.collision_policy,
    ]
    token = args.token if args.token is not None else flux_env().get("FLUXY_TOKEN")
    if token:
        command.extend(["--token", token])
    if args.project_location:
        command.extend(["--project-location", args.project_location])
    if args.no_cleanup:
        command.append("--no-cleanup")
    return run_manage(command)


def field_supervisor(args: argparse.Namespace) -> int:
    command = ["flux_field_supervisor", "--runtime-dir", args.runtime_dir]
    if args.once:
        command.append("--once")
    if args.dry_run:
        command.append("--dry-run")
    if args.base_port is not None:
        command.extend(["--base-port", str(args.base_port)])
    if args.project_path:
        command.extend(["--project-path", args.project_path])
    return run_manage(command)


def mine_parse_l5x(args: argparse.Namespace) -> int:
    return run_uv_mine(["flux-mine", "parse-l5x", args.path])


def mine_parse_l5k(args: argparse.Namespace) -> int:
    return run_uv_mine(["flux-mine", "parse-l5k", args.path])


def mine_source(args: argparse.Namespace) -> int:
    command = ["flux_mine_source", args.path, "--source-type", args.source_type]
    if args.label:
        command.extend(["--label", args.label])
    return run_manage(command)


def build_ignition_tags(args: argparse.Namespace) -> int:
    return run_uv_build(["flux-build", "ignition-tags", args.path, "--output", args.output])


def build_ignition_tags_run(args: argparse.Namespace) -> int:
    return run_manage(["flux_build_ignition_tags", str(args.mine_run_id), "--output", args.output])


def build_hmi_map(args: argparse.Namespace) -> int:
    return run_uv_build(["flux-build", "hmi-map", args.path, "--output-dir", args.output_dir])


def build_hmi_map_run(args: argparse.Namespace) -> int:
    return run_manage(
        ["flux_build_hmi_map", str(args.mine_run_id), "--output-dir", args.output_dir]
    )


def build_seed_hmi_demo(args: argparse.Namespace) -> int:
    command = [
        "seed_build_hmi_demo",
        "--sqlite-path",
        args.sqlite_path,
        "--max-display-screens",
        str(args.max_display_screens),
        "--output-dir",
        args.output_dir,
    ]
    if args.keep_existing:
        command.append("--keep-existing")
    return run_manage(command)


def cell_import(args: argparse.Namespace) -> int:
    command = ["import_cell_csv_bundle", args.path]
    if args.replace:
        command.append("--replace")
    return run_manage(command)


def cell_seed_demo(args: argparse.Namespace) -> int:
    command = ["seed_cell_demo"]
    if args.skip_runtime:
        command.append("--skip-runtime")
    return run_manage(command)


def cell_export(args: argparse.Namespace) -> int:
    return run_manage(["export_cell_csv_bundle", args.bundle_key, "--output", args.output])


def deep_init_hello_world(args: argparse.Namespace) -> int:
    command = ["flux-deep", "init-hello-world", "--output", args.output]
    if args.force:
        command.append("--force")
    return run_uv_deep(command)


def deep_inspect(args: argparse.Namespace) -> int:
    return run_uv_deep(["flux-deep", "inspect", args.path])


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Flux local development helper.")
    subparsers = parser.add_subparsers(dest="command")
    subparsers.add_parser("intro", help="Show the Flux getting-started intro")
    subparsers.add_parser("doctor", help="Check local Flux + Ignition dev-cell health")
    subparsers.add_parser("install-service", help="Install or refresh the user service")
    start = subparsers.add_parser("start", help="Start the Flux background service")
    start.add_argument(
        "--web-mode",
        nargs="?",
        const="gunicorn",
        choices=["gunicorn", "dev", "internal"],
        help="Web serving mode: gunicorn for prod-like workers, dev/internal for Django runserver. Defaults to gunicorn when the flag is present without a value.",
    )
    subparsers.add_parser("stop", help="Stop the Flux background service")
    restart = subparsers.add_parser("restart", help="Restart the Flux background service")
    restart.add_argument(
        "--web-mode",
        nargs="?",
        const="gunicorn",
        choices=["gunicorn", "dev", "internal"],
        help="Web serving mode after restart: gunicorn for prod-like workers, dev/internal for Django runserver. Defaults to gunicorn when the flag is present without a value.",
    )
    subparsers.add_parser("status", help="Show Flux service status")
    subparsers.add_parser("logs", help="Follow Flux service logs")
    subparsers.add_parser("open", help="Open the Flux web UI")
    docs = subparsers.add_parser("docs", help="Serve, build, or open Flux documentation")
    docs_subparsers = docs.add_subparsers(dest="docs_command")
    docs_serve_parser = docs_subparsers.add_parser("serve", help="Start the local docs server")
    docs_serve_parser.add_argument("--host", default="127.0.0.1")
    docs_serve_parser.add_argument("--port", default="8001")
    docs_subparsers.add_parser("build", help="Build the static docs site")
    docs_subparsers.add_parser("open", help="Open the local docs site")

    ignition = subparsers.add_parser("ignition", help="Manage the Flux Ignition dev cell")
    ignition_subparsers = ignition.add_subparsers(dest="ignition_command")

    ignition_subparsers.add_parser("info", help="Show configured Ignition dev-cell paths and URLs")
    doctor = ignition_subparsers.add_parser("doctor", help="Check Gateway + Fluxy WebDev readiness")
    doctor.add_argument(
        "--gateway-url", default=flux_env().get("IGNITION_GATEWAY_URL", DEFAULT_GATEWAY_URL)
    )
    doctor.add_argument(
        "--fluxy-base-url", default=flux_env().get("FLUXY_BASE_URL", DEFAULT_FLUXY_BASE_URL)
    )
    doctor.add_argument("--token", default=None)
    doctor.add_argument("--timeout", type=float, default=5.0)
    doctor.add_argument("--open", action="store_true", help="Open manual-attention URLs")

    deploy = ignition_subparsers.add_parser("deploy-fluxy", help="Deploy Fluxy WebDev resources")
    deploy.add_argument("--project-path", default=str(FLUXY_PROJECT))
    deploy.add_argument("--namespace", default="fluxy")
    deploy.add_argument("--auth-token", default=None)
    deploy.add_argument("--clean", action="store_true")
    deploy.add_argument(
        "--no-scan",
        action="store_true",
        help="Do not request an Ignition project scan after deploy",
    )

    scan = ignition_subparsers.add_parser("request-scan", help="Ask Ignition to rescan the project")
    scan.add_argument(
        "--fluxy-base-url", default=flux_env().get("FLUXY_BASE_URL", DEFAULT_FLUXY_BASE_URL)
    )
    scan.add_argument("--token", default=None)
    ignition_subparsers.add_parser("open", help="Open the Ignition Gateway home page")

    mine = subparsers.add_parser(
        "mine", help="Recover PLC/HMI primitives from legacy SCADA projects"
    )
    mine_subparsers = mine.add_subparsers(dest="mine_command", required=True)
    mine_source_parser = mine_subparsers.add_parser(
        "source", help="Persist mine facts from a PLC or FactoryTalk source"
    )
    mine_source_parser.add_argument(
        "path",
        help="Path to an .L5X/.L5K file, FactoryTalk XML/PAR file, FactoryTalk directory, or FactoryTalk ZIP",
    )
    mine_source_parser.add_argument(
        "--source-type",
        default="auto",
        choices=["auto", "plc", "plc_l5x", "plc_l5k", "factorytalk"],
    )
    mine_source_parser.add_argument("--label", default="", help="Optional label for the mine run")
    mine_l5x = mine_subparsers.add_parser("parse-l5x", help="Parse an L5X file and print a summary")
    mine_l5x.add_argument("path", help="Path to an L5X file")
    mine_l5k = mine_subparsers.add_parser("parse-l5k", help="Parse an L5K file and print a summary")
    mine_l5k.add_argument("path", help="Path to an L5K file")

    build = subparsers.add_parser("build", help="Generate target artifacts from mined primitives")
    build_subparsers = build.add_subparsers(dest="build_command", required=True)
    build_tags = build_subparsers.add_parser(
        "ignition-tags", help="Generate Ignition tag provider JSON from an L5X/L5K file"
    )
    build_tags.add_argument("path", help="Path to an L5X/L5K file")
    build_tags.add_argument("--output", required=True, help="Path to generated provider JSON")
    build_tags_run = build_subparsers.add_parser(
        "ignition-tags-run", help="Generate Ignition tag provider JSON from a persisted mine run"
    )
    build_tags_run.add_argument("mine_run_id", type=int, help="Mine run id to build from")
    build_tags_run.add_argument("--output", required=True, help="Path to generated provider JSON")
    build_hmi = build_subparsers.add_parser(
        "hmi-map", help="Generate symbolic HMI map artifacts from an HMI source"
    )
    build_hmi.add_argument("path", help="Path to FactoryTalk XML/PAR directory or ZIP")
    build_hmi.add_argument(
        "--output-dir", required=True, help="Directory for generated HMI map artifacts"
    )
    build_hmi_run = build_subparsers.add_parser(
        "hmi-map-run", help="Generate symbolic HMI map artifacts from a persisted HMI mine run"
    )
    build_hmi_run.add_argument("mine_run_id", type=int, help="HMI mine run id to build from")
    build_hmi_run.add_argument(
        "--output-dir", required=True, help="Directory for generated HMI map artifacts"
    )
    build_seed = build_subparsers.add_parser(
        "seed-hmi-demo", help="Seed the verified HMI SQLite demo sample"
    )
    build_seed.add_argument(
        "--sqlite-path",
        default=str(ROOT_DIR / "local_hmi_sqlite_export" / "conversion_data.sqlite3"),
    )
    build_seed.add_argument("--max-display-screens", type=int, default=8)
    build_seed.add_argument("--output-dir", default="/tmp/opencode/flux-build-hmi-demo")
    build_seed.add_argument("--keep-existing", action="store_true")

    cell = subparsers.add_parser("cell", help="Manage Flux.cell process collection CSV workflows")
    cell_subparsers = cell.add_subparsers(dest="cell_command", required=True)
    cell_seed_parser = cell_subparsers.add_parser(
        "seed-demo", help="Seed a sample Flux.cell bundle"
    )
    cell_seed_parser.add_argument(
        "--skip-runtime", action="store_true", help="Do not seed runtime or trace cache values"
    )
    cell_import_parser = cell_subparsers.add_parser("import", help="Import a Flux.cell CSV bundle")
    cell_import_parser.add_argument("path", help="Directory containing cells.csv and points.csv")
    cell_import_parser.add_argument(
        "--replace",
        action="store_true",
        help="Replace existing cells/points for bundles in cells.csv",
    )
    cell_export_parser = cell_subparsers.add_parser(
        "export", help="Export Flux.cell Live/Trace CSV views"
    )
    cell_export_parser.add_argument("bundle_key", help="Cell bundle key to export")
    cell_export_parser.add_argument(
        "--output", required=True, help="Output directory for exported CSV files"
    )

    deep = subparsers.add_parser("deep", help="Manage Flux.Deep OpenPLC emulation workspaces")
    deep_subparsers = deep.add_subparsers(dest="deep_command", required=True)
    deep_hello = deep_subparsers.add_parser(
        "init-hello-world", help="Create the starter Logix/OpenPLC hello_world workspace"
    )
    deep_hello.add_argument(
        "--output",
        default=str(ROOT_DIR / ".runtime" / "flux-deep" / "hello_world"),
        help="Output workspace directory",
    )
    deep_hello.add_argument("--force", action="store_true", help="Overwrite generated files")
    deep_inspect_parser = deep_subparsers.add_parser(
        "inspect", help="Print a Flux.Deep workspace manifest"
    )
    deep_inspect_parser.add_argument("path", help="Workspace directory containing manifest.json")

    field = subparsers.add_parser("field", help="Manage Flux FieldAgent simulation workflow")
    field_subparsers = field.add_subparsers(dest="field_command")

    import_tags = field_subparsers.add_parser(
        "import-tag-data", help="Import tag_data inventory and provider JSON"
    )
    import_tags.add_argument("provider", help="Provider name to import, for example Tag_02")
    import_tags.add_argument("--devices", required=True, help="Path to device inventory text file")
    import_tags.add_argument("--tags", required=True, help="Path to Ignition provider JSON export")
    import_tags.add_argument("--skip-raw-config", action="store_true")

    import_live = field_subparsers.add_parser(
        "import-live", help="Import live Ignition provider export and device list"
    )
    import_live.add_argument(
        "source_provider", help="Ignition provider name to export, for example default"
    )
    import_live.add_argument(
        "--provider", help="Flux catalog provider name. Defaults to source_provider."
    )
    import_live.add_argument(
        "--base-url", default=flux_env().get("FLUXY_BASE_URL", DEFAULT_FLUXY_BASE_URL)
    )
    import_live.add_argument("--token", default=None)
    import_live.add_argument("--skip-raw-config", action="store_true")

    materialize = field_subparsers.add_parser(
        "materialize", help="Materialize enabled sim devices into FieldAgent config"
    )
    materialize.add_argument(
        "--provider", help="Optional provider name to materialize, for example Tag_02"
    )

    configure = field_subparsers.add_parser(
        "configure-ignition", help="Configure Ignition for enabled FieldAgent endpoints"
    )
    configure.add_argument(
        "--base-url", default=flux_env().get("FLUXY_BASE_URL", DEFAULT_FLUXY_BASE_URL)
    )
    configure.add_argument("--token", default=None)
    configure.add_argument("--project-location", default=flux_env().get("FLUXY_PROJECT_LOCATION"))
    configure.add_argument("--tag-provider", default="default")
    configure.add_argument("--tag-folder", default="FieldAgent")
    configure.add_argument("--collision-policy", default="o", choices=["a", "m", "o", "i"])
    configure.add_argument("--no-cleanup", action="store_true")

    supervisor = field_subparsers.add_parser(
        "supervisor", help="Run supervised per-device FieldAgent processes"
    )
    supervisor.add_argument("--runtime-dir", default=str(ROOT_DIR / ".runtime" / "field-agent"))
    supervisor.add_argument("--once", action="store_true")
    supervisor.add_argument("--dry-run", action="store_true")
    supervisor.add_argument("--base-port", type=int, default=None)
    supervisor.add_argument("--project-path", default=None)
    return parser.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    platform_status = require_linux()
    if platform_status:
        return platform_status
    args = parse_args(argv)
    command = args.command or "intro"
    if command == "intro":
        print(INTRO)
        return 0
    if command == "doctor":
        return doctor()
    if command == "install-service":
        return run_script("flux-service-install")
    if command == "start":
        return run_script("flux-service-start", service_env(args))
    if command == "stop":
        return run_script("flux-service-stop")
    if command == "restart":
        stop_status = run_script("flux-service-stop")
        start_status = run_script("flux-service-start", service_env(args))
        return start_status if start_status else stop_status
    if command == "status":
        return run_script("flux-service-status")
    if command == "logs":
        return run_script("flux-service-logs")
    if command == "open":
        return open_ui()
    if command == "docs":
        docs_command = args.docs_command or "serve"
        if docs_command == "serve":
            return docs_serve(args)
        if docs_command == "build":
            return docs_build(args)
        if docs_command == "open":
            return open_url(DOCS_URL)
    if command == "ignition":
        ignition_command = args.ignition_command or "info"
        if ignition_command == "info":
            return ignition_info()
        if ignition_command == "doctor":
            return ignition_doctor(args)
        if ignition_command == "deploy-fluxy":
            return ignition_deploy_fluxy(args)
        if ignition_command == "request-scan":
            return ignition_request_scan(args)
        if ignition_command == "open":
            return open_url(flux_env()["IGNITION_GATEWAY_URL"].rstrip("/") + "/web/home")
    if command == "mine":
        mine_command = args.mine_command or "parse-l5x"
        if mine_command == "source":
            return mine_source(args)
        if mine_command == "parse-l5x":
            return mine_parse_l5x(args)
        if mine_command == "parse-l5k":
            return mine_parse_l5k(args)
    if command == "build":
        build_command = args.build_command or "ignition-tags"
        if build_command == "ignition-tags":
            return build_ignition_tags(args)
        if build_command == "ignition-tags-run":
            return build_ignition_tags_run(args)
        if build_command == "hmi-map":
            return build_hmi_map(args)
        if build_command == "hmi-map-run":
            return build_hmi_map_run(args)
        if build_command == "seed-hmi-demo":
            return build_seed_hmi_demo(args)
    if command == "cell":
        cell_command = args.cell_command or "import"
        if cell_command == "seed-demo":
            return cell_seed_demo(args)
        if cell_command == "import":
            return cell_import(args)
        if cell_command == "export":
            return cell_export(args)
    if command == "deep":
        deep_command = args.deep_command or "init-hello-world"
        if deep_command == "init-hello-world":
            return deep_init_hello_world(args)
        if deep_command == "inspect":
            return deep_inspect(args)
    if command == "field":
        field_command = args.field_command or "materialize"
        if field_command == "import-tag-data":
            return field_import_tag_data(args)
        if field_command == "import-live":
            return field_import_live(args)
        if field_command == "materialize":
            return field_materialize(args)
        if field_command == "configure-ignition":
            return field_configure_ignition(args)
        if field_command == "supervisor":
            return field_supervisor(args)
    raise AssertionError(f"Unhandled command: {command}")


if __name__ == "__main__":
    raise SystemExit(main())
