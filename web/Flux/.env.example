FLUX_ENVIRONMENT=development
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECRET_KEY=dev-only-insecure-flux-secret-key
STALE_AFTER_SECONDS=120

# SQLite is used when DATABASE_URL is blank.
# Use Postgres for any concurrent web + worker runtime.
DATABASE_URL=postgres://flux:flux@localhost:5432/flux

# Required when the Fluxy WebDev bridge was deployed with AUTH_TOKEN set.
FLUXY_TOKEN=fluxy-auth-integration-token

# QuestDB Trace data plane. Keep default credentials local-only.
QUESTDB_DSN=postgresql://admin:quest@localhost:8812/qdb
QUESTDB_LATEST_CACHE_SECONDS=30
QUESTDB_PROFILE_CACHE_SECONDS=60
QUESTDB_TRACE_CONCURRENCY=8
FLUX_QUESTDB_HOST=localhost
FLUX_QUESTDB_HTTP_PORT=9000
FLUX_QUESTDB_PG_PORT=8812
